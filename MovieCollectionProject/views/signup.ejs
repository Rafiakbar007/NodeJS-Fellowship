<!DOCTYPE html>
<html>
<head>
    <title>Signup</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <nav class="navbar">
        <h2>🎬 Movie Collection</h2>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/signup">Signup</a>
        </div>
    </nav>

    <div class="container">

        <h1>Create Account</h1>

        <form action="/signup" method="POST">

            <input
                type="text"
                name="name"
                placeholder="Enter Name"
                required
            >

            <br><br>

            <input
                type="email"
                name="email"
                placeholder="Enter Email"
                required
            >

            <br><br>

            <input
                type="password"
                name="password"
                placeholder="Enter Password"
                required
            >

            <br><br>

            <button type="submit">
                Signup
            </button>

        </form>

    </div>

</body>
</html>