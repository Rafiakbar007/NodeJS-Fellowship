<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Movie Collection</title>

    <link rel="stylesheet" href="/styles.css">

    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav class="navbar">

        <h2 class="logo">🎬 Movie Collection</h2>

        <div class="nav-links">
            <a href="/" class="active">Home</a>
            <a href="/add-movie">Add Movie</a>
            <a href="/signup">Signup</a>
            <a href="/login">Login</a>
            <a href="/logout" class="logout-btn">Logout</a>
        </div>

    </nav>

    <section class="hero">

        <h1>🎥 My Movie Library</h1>

        <p>
            Organize, rate and track your favorite movies.
        </p>

    </section>

    <div class="movie-grid">

        <% movies.forEach(movie => { %>

            <div class="movie-card">

                <div class="movie-header">

                    <h2><%= movie.movieName %></h2>

                    <span class="rating">
                        ⭐ <%= movie.rating %>/10
                    </span>

                </div>

                <div class="status">

                    <% if(movie.watched){ %>

                        <span class="watched">
                            ✅ Watched
                        </span>

                    <% } else { %>

                        <span class="not-watched">
                            ❌ Not Watched
                        </span>

                    <% } %>

                </div>

                <% if(movie.youtubeLink){ %>

                    <a
                        href="<%= movie.youtubeLink %>"
                        target="_blank"
                        class="youtube-btn"
                    >
                        ▶ Watch Trailer
                    </a>

                <% } %>

                <div class="card-buttons">

                    <% if(!movie.watched){ %>

                        <form
                            action="/watched/<%= movie._id %>"
                            method="POST"
                        >

                            <button
                                class="watch-btn"
                                type="submit"
                            >
                                Mark as Watched
                            </button>

                        </form>

                    <% } %>

                    <form
                        action="/delete/<%= movie._id %>"
                        method="POST"
                    >

                        <button
                            class="delete-btn"
                            type="submit"
                        >
                            Delete
                        </button>

                    </form>

                </div>

            </div>

        <% }) %>

    </div>

</body>
</html>