<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Movie</title>

    <link rel="stylesheet" href="/styles.css">
</head>
<body>

    <nav class="navbar">

        <h2>🎬 Movie Collection</h2>

        <div class="nav-links">
            <a href="/">Home</a>
            <a href="/add-movie">Add Movie</a>
        </div>

    </nav>

    <div class="container">

        <h1>Add New Movie</h1>

        <form action="/movies" method="POST">

            <input
                type="text"
                name="movieName"
                placeholder="Movie Name"
                required
            >

            <br><br>

            <input
                type="number"
                name="rating"
                placeholder="Rating"
                required
            >

            <br><br>

            <input
                type="text"
                name="youtubeLink"
                placeholder="YouTube Link"
            >

            <br><br>

            <button type="submit">
                Add Movie
            </button>

        </form>

    </div>

</body>
</html>